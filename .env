# ============================================================
#  CrowdWisdomTrading SEC Agent - Environment Variables
# ============================================================

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter base URL (do not change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free LLM model via OpenRouter (change if desired)
LLM_MODEL=mistralai/mistral-7b-instruct:free

# Apify API Token (https://console.apify.com/account/integrations)
APIFY_API_TOKEN=your_apify_api_token_here

# SEC EDGAR - no key needed, but set your user agent
SEC_USER_AGENT=YourName your@email.com

# ChromaDB persistence directory
CHROMA_DB_PATH=./data/chroma_db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
